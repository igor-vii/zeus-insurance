{
  "name": "@workspace/contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Smart contract development with Hardhat and OpenZeppelin",
  "scripts": {
    "compile": "HARDHAT_DISABLE_TELEMETRY_PROMPT=true hardhat compile",
    "test": "HARDHAT_DISABLE_TELEMETRY_PROMPT=true hardhat test",
    "coverage": "HARDHAT_DISABLE_TELEMETRY_PROMPT=true hardhat coverage",
    "deploy:local": "HARDHAT_DISABLE_TELEMETRY_PROMPT=true hardhat run scripts/deploy.js --network localhost",
    "deploy:baseSepolia": "HARDHAT_DISABLE_TELEMETRY_PROMPT=true hardhat run scripts/deploy.js --network baseSepolia",
    "node": "HARDHAT_DISABLE_TELEMETRY_PROMPT=true hardhat node",
    "clean": "hardhat clean"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.2.0",
    "@types/mocha": ">=9.1.0",
    "chai": "^4.2.0",
    "hardhat": "^2.22.17",
    "hardhat-gas-reporter": "^1.0.8",
    "solidity-coverage": "^0.8.1",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.3.0",
    "dotenv": "^16.5.0",
    "ethers": "^6.13.5"
  }
}
